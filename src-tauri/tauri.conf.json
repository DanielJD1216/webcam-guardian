{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Webcam Guardian",
  "version": "0.2.0",
  "identifier": "com.danieljd1216.webcamguardian",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [
      {
        "title": "Webcam Guardian",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$APPCONFIG/**",
          "$APPLOCALDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local webcam guardian + bring-your-own detective",
    "longDescription": "Two-tier webcam guardian. A local RT-DETR guard watches your webcam for free; a frontier multimodal model of your choice is called only when judgment is needed. Alerts go to Telegram + email.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}