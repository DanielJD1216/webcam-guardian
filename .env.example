# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Detective API key — the variable NAME must match detective.api_key_env in config.yaml.
# Leave empty / unused for keyless local servers (e.g. Ollama).
MINIMAX_API_KEY=

# Alert channels
TELEGRAM_BOT_TOKEN=
# Gmail requires an App Password (Google Account -> Security -> 2-Step Verification -> App passwords).
# Your normal account password will NOT work over SMTP.
EMAIL_APP_PASSWORD=
